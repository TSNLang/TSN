import * as console from "std:console";

function main(): void {
    console.log("Testing Managed Pointers (v0.15.1)");
    
    let p: ptr<i32> = 42;
    console.log("Value p.get:");
    print_i32(p.get);
    
    console.log("Updating p = 100");
    p = 100;
    print_i32(p.get);
    
    console.log("Managed string pointer:");
    let s: ptr<string> = "TSN Smart Pointer";
    console.log(s.get);
}

declare function print_i32(n: i32): void;

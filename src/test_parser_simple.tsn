// test_parser_simple.tsn - Simple test for parser functions
// Tests individual parser functions without global state

// Mock structures
interface Token {
    kind: i32;
    start: i32;
    length: i32;
    line: i32;
    column: i32;
}

interface ASTNode {
    kind: i32;
    data1: i32;
    data2: i32;
    data3: i32;
    data4: i32;
    line: i32;
    column: i32;
}

// Constants
const TK_EOF: i32 = 0;
const TK_NUMBER: i32 = 2;
const AST_NUMBER_LITERAL: i32 = 136;

// Global state
let tokens: Token[100];
let tokenCount: i32 = 0;
let nodes: ASTNode[100];
let nodeCount: i32 = 0;
let currentPos: i32 = 0;

// Helper functions
function is_at_end(): i32 {
    let tok: Token = tokens[currentPos];
    return tok.kind == TK_EOF;
}

function current_token(): Token {
    return tokens[currentPos];
}

function advance(): Token {
    if (is_at_end() == 0) {
        currentPos = currentPos + 1;
    }
    return tokens[currentPos - 1];
}

function match(kind: i32): i32 {
    let tok: Token = current_token();
    if (tok.kind == kind) {
        advance();
        return 1;
    }
    return 0;
}

function new_node(kind: i32): i32 {
    let idx: i32 = nodeCount;
    nodes[idx].kind = kind;
    nodes[idx].data1 = 0;
    nodes[idx].data2 = 0;
    nodes[idx].data3 = 0;
    nodes[idx].data4 = 0;
    let tok: Token = current_token();
    nodes[idx].line = tok.line;
    nodes[idx].column = tok.column;
    nodeCount = nodeCount + 1;
    return idx;
}

// Simple parser function
function parse_number(): i32 {
    if (match(TK_NUMBER)) {
        let node: i32 = new_node(AST_NUMBER_LITERAL);
        return node;
    }
    return 0;
}

// Test function
function main(): i32 {
    // Setup: Create a number token
    tokens[0].kind = TK_NUMBER;
    tokens[0].start = 0;
    tokens[0].length = 1;
    tokens[0].line = 1;
    tokens[0].column = 1;
    
    tokens[1].kind = TK_EOF;
    tokens[1].start = 1;
    tokens[1].length = 0;
    tokens[1].line = 1;
    tokens[1].column = 2;
    
    tokenCount = 2;
    currentPos = 0;
    nodeCount = 0;
    
    // Parse the number
    let nodeIdx: i32 = parse_number();
    
    // Check result
    if (nodeIdx == 0) {
        return 1; // Success: created node at index 0
    }
    
    return 0; // Failure
}

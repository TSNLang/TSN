let pos: i32;
let line: i32;
let column: i32;

// Initialize lexer
function lexer_init(src: ptr<i8>, len: i32): void {
    source = src;
    sourceLen = len;
    tokenCount = 0;
    pos = 0;
    line = 1;
    column = 1;
}

// Helper: Check if character is whitespace
function is_whitespace(c: i32): i32 {
    if (c == CHAR_SPACE) return 1;
    if (c == CHAR_TAB) return 1;
    if (c == CHAR_NEWLINE) return 1;
    if (c == 13) return 1; // CR
    return 0;
}

// Helper: Check if character is digit
function is_digit(c: i32): i32 {
    if (c >= CHAR_ZERO) {
        if (c <= CHAR_NINE) {
            return 1;
        }
    }
    return 0;
}

// Helper: Check if character is letter
function is_letter(c: i32): i32 {
    if (c >= CHAR_A_LOWER) {
        if (c <= CHAR_Z_LOWER) {
            return 1;
        }
    }
    if (c >= CHAR_A_UPPER) {
        if (c <= CHAR_Z_UPPER) {
            return 1;
        }
    }
    if (c == CHAR_UNDERSCORE) return 1;
    return 0;
}

// Helper: Check if character is alphanumeric
function is_alnum(c: i32): i32 {
    if (is_letter(c)) return 1;
    if (is_digit(c)) return 1;
    return 0;
}

// Helper: Get current character
function current_char(): i32 {
    if (pos >= sourceLen) return 0;
    return string_char_at(source, pos);
}

// Helper: Peek next character
function peek_char(): i32 {
    if (pos + 1 >= sourceLen) return 0;
    return string_char_at(source, pos + 1);
}

// Helper: Advance position
function advance(): void {
    let c: i32 = current_char();
    pos = pos + 1;
    if (c == CHAR_NEWLINE) {
        line = line + 1;
        column = 1;
    }
    else {
        column = column + 1;
    }
}

// Helper: Add token
function add_token(kind: i32, start: i32, length: i32): void {
    tokens[tokenCount].kind = kind;
    tokens[tokenCount].start = start;
    tokens[tokenCount].length = length;
    tokens[tokenCount].line = line;
    tokens[tokenCount].column = column;
    tokenCount = tokenCount + 1;
}

// Skip whitespace and comments
function skip_whitespace(): void {
    while (pos < sourceLen) {
        
        if (is_whitespace(c)) {
            advance();
        }
        else if (c == CHAR_SLASH) {
            let next: i32 = peek_char();
            if (next == CHAR_SLASH) {
                // Single-line comment
                advance();
                advance();
                while (pos < sourceLen) {
                    let ch: i32 = current_char();
                    if (ch == CHAR_NEWLINE) break;
                    advance();
                }
            }
            else if (next == CHAR_STAR) {
                // Multi-line comment
                advance();
                advance();
                while (pos < sourceLen) {
                    if (ch == CHAR_STAR) {
                        if (peek_char() == CHAR_SLASH) {
                            advance();
                            advance();
                            break;
                        }
                    }
                    advance();
                }
            }
            else {
                break;
            }
        }
        else {
            break;
        }
    }
}

// Helper: Compare string at position with keyword
function match_keyword(start: i32, length: i32, keyword: ptr<i8>, keywordLen: i32): i32 {
    if (length != keywordLen) return 0;
    
    let i: i32 = 0;
    while (i < length) {
        let c1: i32 = string_char_at(source, start + i);
        let c2: i32 = string_char_at(keyword, i);
        if (c1 != c2) return 0;
        i = i + 1;
    }
    
    return 1;
}

// Helper: Get keyword token kind
function get_keyword_kind(start: i32, length: i32): i32 {
    // Check length first for optimization
    if (length == 2) {
        // "if"
        if (string_char_at(source, start) == 105) { // 'i'
            if (string_char_at(source, start + 1) == 102) { // 'f'
                return TK_IF;
            }
        }
    }
    else if (length == 3) {
        let c0: i32 = string_char_at(source, start);
        
        // "let"
        if (c0 == 108) { // 'l'
            if (c1 == 101) { // 'e'
                if (c2 == 116) { // 't'
                    return TK_LET;
                }
            }
        }
        // "for"
        else if (c0 == 102) { // 'f'
            if (c1 == 111) { // 'o'
                if (c2 == 114) { // 'r'
                    return TK_FOR;
                }
            }
        }
    }
    else if (length == 4) {
        let c3: i32 = string_char_at(source, start + 3);
        
        // "else"
        if (c0 == 101) { // 'e'
            if (c1 == 108) { // 'l'
                if (c2 == 115) { // 's'
                    if (c3 == 101) { // 'e'
                        return TK_ELSE;
                    }
                }
            }
        }
        // "true"
        else if (c0 == 116) { // 't'
            if (c1 == 114) { // 'r'
                if (c2 == 117) { // 'u'
                    if (c3 == 101) { // 'e'
                        return TK_TRUE;
                    }
                }
            }
        }
        // "null"
        else if (c0 == 110) { // 'n'
            if (c1 == 117) { // 'u'
                if (c2 == 108) { // 'l'
                    if (c3 == 108) { // 'l'
                        return TK_NULL;
                    }
                }
            }
        }
    }
    else if (length == 5) {
        let c4: i32 = string_char_at(source, start + 4);
        
        // "const"

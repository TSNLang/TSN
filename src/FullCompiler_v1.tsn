                    if (c3 == 117) { // 'u'
                        if (c4 == 114) { // 'r'
                            if (c5 == 110) { // 'n'
                                return TK_RETURN;
                            }
                        }
                    }
                }
            }
        }
    }
    else if (length == 7) {
        
        // "declare"
        if (c0 == 100) { // 'd'

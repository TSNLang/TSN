// Minimal test to check if parsing works

const TK_KW_FUNCTION: i32 = 30;

interface ASTNode {
    kind: i32;
    value1: i32;
    value2: i32;
    value3: i32;
}

const AST_FUNCTION: i32 = 20;

function test_parse(): i32 {
    // Create a simple token array
    let tokens: i32[10];
    tokens[0] = 30;  // TK_KW_FUNCTION
    
    // Check if first token is function keyword
    if (tokens[0] == TK_KW_FUNCTION) {
        return 1;  // Success
    } else {
        return 0;  // Fail
    }
}

function main(): i32 {
    return test_parse();
}

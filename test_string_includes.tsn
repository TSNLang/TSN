import * as console from "std:console";

function main(): void {
    let s = "Chào thế giới! 🌍";
    console.log(s);

    if (s.includes("thế giới")) {
        console.log("Found: thế giới");
    }

    if (s.includes("🌍")) {
        console.log("Found: Emoji 🌍");
    }

    if (s.includes("TSN")) {
        console.log("Found: TSN");
    } else {
        console.log("Not found: TSN");
    }
}

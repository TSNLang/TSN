import Optional from "std:option";
import * as option from "std:option";
import * as console from "std:console";

function main(): i32 {
    let x = option.Some<i32>(42);
    if (x.isSome()) {
        console.log("Option has value!");
    }
    
    let y = option.None<string>();
    if (y.isNone()) {
        console.log("Option is None!");
    }
    
    return 0;
}

// Test function call with many parameters

function test_func(a: ptr<i32>, b: ptr<i32>, c: ptr<i32>, d: ptr<i32>, e: ptr<i32>, f: ptr<i32>, g: ptr<i8>): i32 {
    return a[0];
}

function main(): i32 {
    let arr1: i32[10];
    let arr2: i32[10];
    let arr3: i32[10];
    let arr4: i32[10];
    let arr5: i32[10];
    let arr6: i32[10];
    let str = "test";
    
    arr1[0] = 42;
    
    let result = test_func(arr1, arr2, arr3, arr4, arr5, arr6, str);
    return result;
}

// Test case: Array member assignment (the bug we're fixing!)
interface ASTNode {
    kind: i32;
    value: i32;
}

function test(): i32 {
    let nodes: ASTNode[3];
    let idx: i32 = 0;
    
    // This is the critical line that C++ compiler couldn't handle!
    nodes[idx].kind = 42;
    nodes[idx].value = 100;
    
    // Read it back
    let result: i32 = nodes[0].kind;
    return result;
}

// Complete test with main function
interface ASTNode {
    kind: i32;
    value: i32;
}

function test(): i32 {
    let nodes: ASTNode[3];
    let idx: i32 = 0;
    
    // The critical array member assignment!
    nodes[idx].kind = 42;
    nodes[idx].value = 100;
    
    // Read it back
    return nodes[0].kind;
}

function main(): i32 {
    let result: i32 = test();
    return result;
}

import * as console from "std:console";

interface Wrapper<T> {
  value: T;
  getValue(): T;
}

class StringWrapper implements Wrapper<string> {
  value: string;
  
  constructor(v: string) {
    this.value = v;
  }
  
  getValue(): string {
    return this.value;
  }
}

function main(): i32 {
  let w: Wrapper<string> = new StringWrapper("Hello Generic Interface!");
  let val: string = w.getValue();
  console.log(val);
  return 0;
}

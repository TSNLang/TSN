// Test FFI with actual call
import * as console from "std:console";

@ffi.lib("kernel32")
declare function GetStdHandle(nStdHandle: u32): ptr<void>;

function main(): void {
    console.log("Testing FFI call...");
    let h = GetStdHandle(4294967285);  // STD_OUTPUT_HANDLE = -11 = 0xFFFFFFF5
    console.log("FFI call successful!");
}

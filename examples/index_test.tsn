import * as console from "std:console";

function main() {
    let s = "hello";
    let c = s[0];
    // console.log("First char is:");
    // In TSN, we don't have i32 to string conversion for log yet, 
    // but we can check if it compiles and runs.
    if (c == 104) { // 'h' is 104
        console.log("Matched 'h'");
    }
}

import * as console from "std:console";

// Test string operations for self-hosting compiler

function test_string_length() {
    let s = "hello";
    let len = string_length(s);
    console.log("String length test");
}

function test_string_char_at() {
    let s = "function";
    let c = string_char_at(s, 0);  // Should be 'f' = 102
    if (c == 102) {
        console.log("Char at test passed");
    }
}

function test_string_equals() {
    let s1 = "function";
    let s2 = "function";
    let s3 = "return";
    
    if (string_equals(s1, s2)) {
        console.log("String equals test 1 passed");
    }
    
    if (string_equals(s1, s3) == false) {
        console.log("String equals test 2 passed");
    }
}

function test_string_concat() {
    let s1 = "define ";
    let s2 = "i32 @main()";
    let result: ptr<i8>;
    result = string_concat(s1, s2);
    console.log("String concat test");
}

function main() {
    console.log("=== String Operations Test ===");
    test_string_length();
    test_string_char_at();
    test_string_equals();
    test_string_concat();
    console.log("All string tests completed!");
}

import * as console from "std:console";
import * as str from "std:string";

function sum(...values: i32[]): i32 {
    let total: i32 = 0;
    let i: i32 = 0;
    while (i < values.length) {
        total = total + values.get(i);
        i = i + 1;
    }
    return total;
}

function main(): i32 {
    let result = sum(1, 2, 3, 4);
    console.log(str.fromInt(result as i64));
    return 0;
}

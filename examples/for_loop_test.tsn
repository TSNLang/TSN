import * as console from "std:console";

function main() {
    // Test 1: Simple for loop
    console.log("Test 1: Simple counting");
    for (let i = 0; i < 5; i = i + 1) {
        console.log("Loop iteration");
    }
    
    // Test 2: For loop with array
    console.log("Test 2: Array initialization");
    let numbers: i32[10];
    for (let i = 0; i < 10; i = i + 1) {
        numbers[i] = i * 2;
    }
    console.log("Array initialized");
    
    // Test 3: Nested for loops
    console.log("Test 3: Nested loops");
    for (let i = 0; i < 3; i = i + 1) {
        for (let j = 0; j < 2; j = j + 1) {
            console.log("Nested iteration");
        }
    }
    
    console.log("All for loop tests passed!");
}

// Test control flow statements

function if_test(): i32 {
    let x: i32 = 10;
    if (x > 5) {
        return 1;
    }
    return 0;
}

function while_test(): i32 {
    let i: i32 = 0;
    let sum: i32 = 0;
    while (i < 5) {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

function nested_test(): i32 {
    let x: i32 = 10;
    if (x > 0) {
        let i: i32 = 0;
        while (i < 3) {
            x = x + 1;
            i = i + 1;
        }
    }
    return x;
}
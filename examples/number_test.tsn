import * as console from "std:console";

function main() {
    // Test với kiểu number (ánh xạ sang f64)
    let x: number = 3.14;
    let y: number = 2.0;
    let z = x * y;
    
    // Test với f32
    let a: f32 = 1.5f;
    let b: f32 = 2.5f;
    
    // Test với f64 tường minh
    let c: f64 = 10.5;
    let d: f64 = 20.3;
    
    console.log("Number type test completed");
}

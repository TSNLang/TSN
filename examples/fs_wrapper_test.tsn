@ffi.lib("kernel32")
declare function CreateFileA(path: ptr<u8>, access: u32, share: u32, sa: ptr<void>, disp: u32, flags: u32, temp: ptr<void>): ptr<void>;
@ffi.lib("kernel32")
declare function WriteFile(h: ptr<void>, buf: ptr<void>, len: u32, written: ptr<u32>, over: ptr<void>): bool;
@ffi.lib("kernel32")
declare function CloseHandle(h: ptr<void>): bool;

const GENERIC_WRITE = 1073741824;
const CREATE_ALWAYS = 2;

import * as console from "std:console";

function writeFileSync(path: ptr<u8>, data: ptr<u8>, len: u32): bool {
    let h = CreateFileA(path, GENERIC_WRITE, 0, null, CREATE_ALWAYS, 128, null);
    let written = 0;
    let ok = WriteFile(h, data, len, &written, null);
    CloseHandle(h);
    return ok;
}

function main() {
    console.log("testing writeFileSync wrapper");
    let ok = writeFileSync("wrapper_test.txt", "hello from wrapper", 18);
    console.log("write call finished");
}


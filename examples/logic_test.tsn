import * as console from "std:console";

function test(a: i32, b: i32) {
    if (a < b) {
        console.log("a < b is true");
    } else {
        console.log("a < b is false");
    }

    if (a == 10) {
        console.log("a is 10");
    }
}

function main() {
    console.log("testing logic");
    test(5, 10);
    test(20, 10);
    test(10, 10);
}

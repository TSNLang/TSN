import * as console from "std:console";

interface Point {
    x: i32;
    y: i32;
}

interface Token {
    kind: i32;
    pos: i32;
    len: i32;
}

function main() {
    // Test 1: Initialize and modify Point
    let p: Point = { x: 10, y: 20 };
    console.log("Point initialized");
    
    // Modify fields
    p.x = 100;
    p.y = 200;
    console.log("Point modified");
    
    // Read back
    let px = p.x;
    let py = p.y;
    console.log("Point values read back");
    
    // Test 2: Token with multiple fields
    let tok: Token = { kind: 1, pos: 0, len: 5 };
    console.log("Token initialized");
    
    // Modify all fields
    tok.kind = 2;
    tok.pos = 10;
    tok.len = 15;
    console.log("Token modified");
    
    // Read back
    let k = tok.kind;
    let p2 = tok.pos;
    let l = tok.len;
    console.log("Token values read back");
    
    console.log("All member write tests passed!");
}

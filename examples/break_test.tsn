// Test break statement

function test_break(): i32 {
    let i: i32 = 0;
    let sum: i32 = 0;
    
    while (i < 10) {
        if (i == 5) {
            break;
        }
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;  // Should return 0+1+2+3+4 = 10
}

function test_continue(): i32 {
    let i: i32 = 0;
    let sum: i32 = 0;
    
    while (i < 5) {
        i = i + 1;
        if (i == 3) {
            continue;
        }
        sum = sum + i;
    }
    
    return sum;  // Should return 1+2+4+5 = 12 (skips 3)
}

import * as console from "std:console";

function add(a: f64, b: f64): f64 {
    return a + b;
}

function multiply(x: f64, y: f64): f64 {
    return x * y;
}

function main() {
    let pi: f64 = 3.14159;
    let radius: f64 = 5.0;
    let area = pi * radius * radius;
    
    let result = add(10.5, 20.3);
    let product = multiply(2.5, 4.0);
    
    console.log("Float test completed");
}

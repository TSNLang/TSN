import * as console from "std:console";

function get_first(arr: ptr<i32>): i32 {
    return arr[0];
}

function main() {
    let numbers: i32[3];
    numbers[0] = 42;
    numbers[1] = 100;
    numbers[2] = 200;
    
    let first = get_first(numbers);
    
    console.log("Simple array pass test");
}

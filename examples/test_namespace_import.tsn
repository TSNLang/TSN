// Test namespace import (import * as)

import * as math from "./math_module.tsn";

function main(): i32 {
    // Note: Currently we can't use math.add() syntax yet
    // because that requires member access on namespaces
    // For now, functions are still in global scope
    let x = add(15, 25);
    let y = multiply(3, 4);
    return add(x, y);  // 40 + 12 = 52
}

// Test variable declarations and assignments

function var_test(): i32 {
    let x: i32 = 10;
    let y: i32 = 20;
    return x + y;
}

function assign_test(): i32 {
    let x: i32 = 5;
    x = 15;
    return x;
}

function no_init_test(): i32 {
    let x: i32;
    x = 42;
    return x;
}